DATABASE_URL=postgresql://signal:signal@localhost:5544/signal_harvester
PORT=3010
HOST=0.0.0.0
MARKET_BACKFILL_ENABLED=1
# Aggressive but bounded Binance backfill: target 3,000 request-weight/minute.
# This is 50% of Binance's documented 6,000 request-weight/minute limit; auto-throttle reacts to 429/418 Retry-After.
MARKET_BACKFILL_TARGET_WEIGHT_PER_MINUTE=3000
MARKET_BACKFILL_MAX_CONCURRENCY=16
MARKET_BACKFILL_MIN_INTERVAL_MS=20
MARKET_BACKFILL_BATCH_SIZE=1000
